# ============================================================
# secrets.fish — machine-local WORK CONFIG (non-secret values only).
#
# Copy to ~/.config/fish/conf.d/secrets.fish (install.sh seeds it if missing).
# Gitignored. Safe for non-secret work config — do NOT put credentials here.
#
# Real credentials live in the macOS Keychain and are pulled into a shell on
# demand via the `load-secrets` function (see shell/load_secrets.fish).
# Store each one once:
#   security add-generic-password -s mac-setup -a AWS_RELEASES_ACCESS_KEY     -w '<value>' -U
#   security add-generic-password -s mac-setup -a AWS_RELEASES_SECRET_KEY     -w '<value>' -U
#   security add-generic-password -s mac-setup -a CYPRESS_MP_SERVICE_MANAGER_PWD -w '<value>' -U
#   security add-generic-password -s mac-setup -a CYPRESS_AUTH0_CLIENT_SECRET -w '<value>' -U
#   security add-generic-password -s mac-setup -a CYPRESS_MP_ADMIN_PWD        -w '<value>' -U
# Then run `load-secrets` in any shell that needs them.
# ============================================================

# --- Non-secret work config (safe to keep here) ---
# set -gx AWS_PROFILE <your-default-profile>
# set -gx KOPS_STATE_STORE s3://<your-kops-store>

# --- Cypress non-secret config (usernames + Auth0 IDs; NOT passwords) ---
# set -gx CYPRESS_MP_SERVICE_MANAGER_USERNAME <user>
# set -gx CYPRESS_MP_ADMIN_USERNAME <admin-user>
# set -gx CYPRESS_REACT_APP_AUTH0_DOMAIN <domain>
# set -gx CYPRESS_REACT_APP_AUTH0_AUDIENCE <audience>
# set -gx CYPRESS_REACT_APP_AUTH0_CLIENTID <client-id>

# --- Git commit signing (used by signpersonal/signwork in git.fish) ---
# set -gx GPG_KEY_PERSONAL <your-personal-signing-key>
# set -gx GPG_MAIL_PERSONAL <your-personal-email>
# set -gx GPG_KEY_WORK <your-work-signing-key>
# set -gx GPG_MAIL_WORK <your-work-email>
